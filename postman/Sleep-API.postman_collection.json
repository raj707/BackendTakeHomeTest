{
  "info": {
    "name": "Sleep API",
    "description": "Postman collection for Sleep API validation",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "userId",
      "value": "11111111-1111-1111-1111-111111111111"
    },
    {
      "key": "unknownUserId",
      "value": "22222222-2222-2222-2222-222222222222"
    }
  ],
  "item": [
    {
      "name": "Create Sleep Log - GOOD",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/users/{{userId}}/sleep-logs",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"bedtime\": \"2026-06-23T22:30:00\",\n  \"wakeupTime\": \"2026-06-24T06:30:00\",\n  \"feeling\": \"GOOD\"\n}"
        }
      }
    },
    {
      "name": "Create Sleep Log - OK",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/users/{{userId}}/sleep-logs",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"bedtime\": \"2026-06-23T23:00:00\",\n  \"wakeupTime\": \"2026-06-24T06:00:00\",\n  \"feeling\": \"OK\"\n}"
        }
      }
    },
    {
      "name": "Create Sleep Log - BAD",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/users/{{userId}}/sleep-logs",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"bedtime\": \"2026-06-23T23:30:00\",\n  \"wakeupTime\": \"2026-06-24T05:00:00\",\n  \"feeling\": \"BAD\"\n}"
        }
      }
    },
    {
      "name": "Get Latest Sleep",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/users/{{userId}}/sleep-logs/latest"
      }
    },
    {
      "name": "Get Sleep Summary",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/users/{{userId}}/sleep-logs/summary"
      }
    },
    {
      "name": "Get Latest Sleep - Unknown User",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/users/{{unknownUserId}}/sleep-logs/latest"
      }
    }
  ]
}
